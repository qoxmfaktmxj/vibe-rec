# Spring Boot API 서버 주소 (서버 사이드 전용 - SSR / Route Handler)
API_BASE_URL=http://127.0.0.1:8081/api

# Spring Boot API 서버 주소 (클라이언트 사이드 노출 가능)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8081/api
